PORT=8080
DB_PATH=./data/app.db

CORS_ALLOWED_ORIGINS=https://chinatsu.sappagetti.com

# 認証メールのリンク先API。HTTPSの公開URL（Nginxが /api をバックエンドへ転送するホスト）に合わせる。
APP_BASE_URL=https://chinatsu.sappagetti.com
FRONTEND_BASE_URL=https://chinatsu.sappagetti.com

REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

TURNSTILE_SECRET_KEY=

SMTP_HOST=mail.sappagetti.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@sappagetti.com

# ジャケット画像を内部配信するディレクトリ（例: ./assets/jacket）
JACKET_DIR=./assets/jacket

# プロフィールアイコンを保存・配信するディレクトリ
ICON_DIR=./data/icons

# プロフィールキャラクター画像を保存・配信するディレクトリ
CHARA_DIR=./data/chara

# music-ex.json のミラー設定。
# 上流（OTOGE DB GitHub raw）を24時間に1回ポーリングしてローカルに保存し、
# /api/v1/music-ex.json で配信する。未指定時は以下がデフォルト。
MUSIC_EX_SOURCE_URL=https://raw.githubusercontent.com/zvuc/otoge-db/master/ongeki/data/music-ex.json
MUSIC_EX_CACHE_PATH=./data/music-ex.json
# 手動 譜面定数: Docker Compose では /data/music-ex-overrides.json を推奨
MUSIC_EX_OVERRIDES_PATH=./data/music-ex-overrides.json
