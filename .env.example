# docker-compose 빌드 시 frontend 컨테이너의 build args 로 주입된다.
# 이 파일을 복사해 `.env` 로 만들고 값을 채워 사용한다.

VITE_API_URL=https://chinatsu.sappagetti.com
VITE_BOOKMARKLET_API_URL=https://chinatsu.sappagetti.com

# music-ex.json 을 가져올 URL. 기본은 백엔드가 미러링하는 same-origin 엔드포인트.
# 외부 호스트를 직접 가리키는 경우 frontend/nginx.conf 의 CSP connect-src 도 같이 맞춰야 한다.
VITE_BEATMAP_BUCKET_URL=/api/v1/music-ex.json

VITE_TURNSTILE_SITE_KEY=
